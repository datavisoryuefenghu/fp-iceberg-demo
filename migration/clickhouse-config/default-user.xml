<clickhouse>
  <!-- Override: allow the default user to connect from any IP (needed for Docker port mapping).
       Without this, ClickHouse only allows default user from 127.0.0.1/::1,
       but host→container via Docker NAT appears as the bridge gateway IP. -->
  <users>
    <default>
      <networks>
        <ip>::/0</ip>
      </networks>
    </default>
  </users>
</clickhouse>
